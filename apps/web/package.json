{
  "name": "@storeai/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H ${HOST:-127.0.0.1} -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start -H ${HOST:-127.0.0.1} -p ${PORT:-3000}",
    "lint": "next lint --dir src --dir tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@storeai/auth": "workspace:*",
    "@storeai/db": "workspace:*",
    "@storeai/queue": "workspace:*",
    "@storeai/shared": "workspace:*",
    "@storeai/storage": "workspace:*",
    "drizzle-orm": "^0.33.0",
    "next": "15.5.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.10",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.15",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1",
    "tsx": "^4.19.0"
  }
}
