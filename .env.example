# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=storeai
POSTGRES_PASSWORD=storeai_dev
POSTGRES_DB=storeai
DATABASE_URL=postgres://storeai:storeai_dev@localhost:5434/storeai

# --- Redis ---
REDIS_URL=redis://localhost:6381

# --- MinIO / S3 ---
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=storeai
S3_SECRET_KEY=storeai_dev_secret
S3_BUCKET=storeai-dev
S3_FORCE_PATH_STYLE=true
MINIO_CONSOLE_PORT=9003

# --- App ---
APP_URL=http://localhost:3000
NODE_ENV=development
SESSION_COOKIE_NAME=sa_session
# `pnpm bootstrap` overwrites this with a random 48-byte value. If you write
# your own .env, generate one yourself:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=REPLACE_ME_WITH_A_RANDOM_48_BYTE_BASE64URL_STRING_XXXXXXXXXXXXXXXX
PORT=3000

# --- Seed ---
# On first run `pnpm bootstrap` prompts for these and overwrites the placeholders.
# If you're assembling .env by hand, SET A REAL PASSWORD HERE before running `pnpm db:seed`.
# The placeholder password is intentionally invalid so the seed step refuses
# to create an easy-to-guess admin account.
SEED_ADMIN_EMAIL=admin@storeai.local
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_SEEDING
SEED_TENANT_SLUG=workspace
SEED_TENANT_NAME=My Workspace
