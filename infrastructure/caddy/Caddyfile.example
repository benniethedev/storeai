# Caddy config for StoreAI.
# Rendered into /etc/caddy/Caddyfile by infrastructure/scripts/deploy-domain.sh.
# Caddy auto-issues and auto-renews Let's Encrypt certs on first request.
#
# Manual use:
#   envsubst < Caddyfile.example | sudo tee /etc/caddy/Caddyfile

# Global options block — MUST come before any site block.
# Caddy's adapter rejects any config where a keyless block follows a site
# block ("server block without any key is global configuration, and if used,
# it must be first").
{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode zstd gzip

    # Request body limit (tune up if you expect larger file uploads)
    request_body {
        max_size 60MB
    }

    # Defense-in-depth probe-path block. The app's middleware (apps/web/src/
    # middleware.ts) does the same at the app layer; blocking here saves a
    # hop, keeps scanner traffic out of the Node process entirely, and
    # avoids it touching usage_logs or any app code path.
    @probes {
        path_regexp probes (?i)^/(\.env(\..*|/.*)?|\.git(/.*)?|\.(svn|hg|bzr)(/.*)?|\.DS_Store|\.aws/.*|\.ssh/.*|wp-(admin|login|content|includes|json).*|phpmyadmin.*|adminer.*|(xmlrpc|phpinfo|info|shell|webshell|c99|r57)\.(php|asp|aspx|jsp)|(vendor|storage|backup|dump|db)/[^/]*\.(zip|tar|gz|sql|bak|log|json)|server-status.*|cgi-bin/.*|etc/passwd|proc/self.*)$
    }
    respond @probes 404

    # -- Ops endpoint --------------------------------------------------------
    # Read-only aggregate-metrics endpoint for external monitoring dashboards.
    # Match the path and apply (optionally) an IP allowlist. Uncomment and
    # set `remote_ip <egress-ip>` for each dashboard that should be able to
    # reach it. Leave the allowlist off to permit any Bearer-auth caller —
    # the app-level token check plus the in-route per-token rate limit are
    # the primary gates (see apps/web/src/app/api/ops/overview/route.ts).
    @ops {
        path /api/ops /api/ops/*
        # remote_ip 203.0.113.42     # netswagger dashboard egress
    }
    # Optional edge rate limit. The in-app limit (30 req / 60s per token) is
    # sufficient; enabling this gives defense in depth. Requires the
    # caddy-ratelimit module — NOT in the default apt package. Rebuild Caddy
    # with:
    #     xcaddy build --with github.com/mholt/caddy-ratelimit
    # (or on a recent Caddy: `caddy add-package github.com/mholt/caddy-ratelimit`)
    # rate_limit {
    #     zone ops {
    #         key {http.request.remote_host}
    #         events 5
    #         window 1s
    #         burst 20
    #     }
    #     match {
    #         path /api/ops /api/ops/*
    #     }
    # }

    # Pass through to the Next.js server running on loopback
    reverse_proxy localhost:{$STOREAI_PORT} {
        # Longer timeouts for file uploads and long-running API-key requests
        transport http {
            read_timeout 120s
            write_timeout 120s
        }
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Access log (rotate via logrotate if you enable this persistently)
    log {
        output file /var/log/caddy/storeai-access.log {
            roll_size 10mb
            roll_keep 5
        }
        format console
    }
}
